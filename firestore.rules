rules_version = '2';

// ============================================================
//  FIRESTORE SECURITY RULES — Egypt Tourism App
//  Deploy via Firebase Console → Firestore → Rules
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User data: only the owner can read/write ──
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Admin collections: read-only for all, write for admins ──
    // NOTE: Replace 'ADMIN_UID_HERE' with your actual admin user UID
    //       from Firebase Console → Authentication → Users
    match /admin_places/{docId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin(request.auth.uid);
    }
    match /admin_hotels/{docId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin(request.auth.uid);
    }
    match /admin_trips/{docId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin(request.auth.uid);
    }
    match /admin_restaurants/{docId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin(request.auth.uid);
    }
    match /admin_overrides/{docId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin(request.auth.uid);
    }

    // ── Admin check function ──
    // Option 1: Hardcode admin UIDs (simplest)
    function isAdmin(uid) {
      return uid in [
        'ADMIN_UID_HERE'
        // Add more admin UIDs as needed
      ];
    }

    // Option 2: Use an admin_users collection (more flexible)
    // function isAdmin(uid) {
    //   return exists(/databases/$(database)/documents/admin_users/$(uid));
    // }

    // ── Deny everything else by default ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
